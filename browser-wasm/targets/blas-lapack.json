{
  "name": "blas-lapack",
  "description": "Build a standalone browser Wasm module wrapping OpenBLAS BLAS/LAPACK kernels.",
  "enabledByDefault": false,
  "sourceRootEnv": "NUMBL_BLAS_LAPACK_SRC_ROOT",
  "buildScript": "browser-wasm/wrappers/openblas-linalg/build-openblas-linalg.sh",
  "capabilities": {
    "matmul": true,
    "inv": true,
    "linsolveSquare": true
  },
  "exports": [
    "malloc",
    "free",
    "numbl_matmul_f64",
    "numbl_inv_f64",
    "numbl_linsolve_f64"
  ],
  "output": "public/wasm-kernels/blas-lapack.wasm"
}
