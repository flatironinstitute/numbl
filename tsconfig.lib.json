{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist-lib",
    "outDir": "dist-lib",
    "strict": true,
    "skipLibCheck": true,
    // The generated runtime snippet registry (snippets.gen.ts) re-exports
    // helpers via `export * from "./…js"` pointing at the real `.js` runtime
    // snippet files (the interpreter executes those directly via ESM). Without
    // `allowJs` tsc can't resolve those re-exports and reports every member as
    // missing. `checkJs: false` keeps the `.js` snippets out of type-checking,
    // matching tsconfig.app.json (used by the dev/CI `tsc -b` typecheck).
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client", "node"],
    "erasableSyntaxOnly": false
  },
  "include": [
    "src/lib.ts",
    "src/node.ts",
    "src/cli-fileio.ts",
    "src/cli-system.ts",
    "src/cli-scan.ts",
    "src/numbl-core/**/*.ts",
    "src/graphics/types.ts"
  ]
}
